# TRUTH MD Host Platform — Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────
# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appname>

# ── Auth ──────────────────────────────────────────────────────────
# Strong random string for JWT signing (generate with: openssl rand -hex 32)
JWT_SECRET=replace_with_a_long_random_secret

# ── Admin account ─────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Server ────────────────────────────────────────────────────────
PORT=5000

# ── App URL (REQUIRED for VPS / M-Pesa callbacks) ─────────────────
# The public HTTPS URL of your platform — no trailing slash.
# Example: https://mybot.example.com
APP_URL=https://your-domain.com

# ── GitHub (optional — needed to clone private repos) ─────────────
GITHUB_TOKEN=your_github_pat_here

# ── Email (optional — for purchase receipt emails) ─────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# ── Payflow / M-Pesa (optional — for coin purchases) ──────────────
PAYFLOW_API_KEY=
PAYFLOW_API_SECRET=
PAYFLOW_ACCOUNT_ID=
